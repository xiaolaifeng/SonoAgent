# 智谱 GLM（OpenAI 兼容端点）
ZHIPU_API_KEY=在此填入你的智谱 API Key
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4.5

# 最简登录（固定账号）
AUTH_USERNAME=doctor1
AUTH_PASSWORD=changeme
JWT_SECRET=请改成一串足够长的随机字符串

# 部署路径：留空=根路径（Vercel）；自托管 nginx 子路径填 /chaosheng
NEXT_PUBLIC_BASE_PATH=

# 数据库：本地 SQLite（默认）或 Turso 远程 libSQL（libsql://...）
DB_PATH=file:data.db
# 仅 Turso 远程库需要：TURSO_AUTH_TOKEN=...
